#!/bin/bash
# Pre-commit hook: Prevent accidental commit of sensitive files
# 
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or: git config core.hooksPath .githooks

echo "🔍 Running security checks..."

# Color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

FOUND_ISSUES=0

# Check 1: .env files should not be staged
echo -n "Checking for .env files... "
if git diff --cached --name-only | grep -E '^\.env'; then
    echo -e "${RED}✗ FAIL${NC}"
    echo ".env file detected in staged files!"
    echo "This file contains secrets and should never be committed."
    echo ""
    echo "Remove from staging:"
    echo "  git reset HEAD .env"
    FOUND_ISSUES=1
else
    echo -e "${GREEN}✓ PASS${NC}"
fi

# Check 2: Private key patterns
echo -n "Checking for private keys... "
if git diff --cached -U0 | grep -iE '(private[_]?key|0x[a-f0-9]{64}|private.?=)'; then
    echo -e "${RED}✗ FAIL${NC}"
    echo "Possible private key detected in staged changes!"
    echo ""
    echo "Verify your changes:"
    echo "  git diff --cached"
    FOUND_ISSUES=1
else
    echo -e "${GREEN}✓ PASS${NC}"
fi

# Check 3: API keys and credentials
echo -n "Checking for credentials... "
if git diff --cached | grep -iE '(api[_]?key|password|secret|token)['\''\"\\s]*[:=]'; then
    echo -e "${RED}✗ FAIL${NC}"
    echo "Possible credentials detected in staged changes!"
    echo ""
    echo "Verify your changes:"
    echo "  git diff --cached | grep -iE '(api_key|password|secret|token)'"
    FOUND_ISSUES=1
else
    echo -e "${GREEN}✓ PASS${NC}"
fi

# Check 4: Results directory
echo -n "Checking results/ directory... "
if git diff --cached --name-only | grep -E '^results/'; then
    echo -e "${YELLOW}⚠ WARNING${NC}"
    echo "Results directory detected (contains transaction data)"
    echo "This usually shouldn't be committed."
    echo ""
    echo "If intentional, use:"
    echo "  git commit --no-verify"
fi

# Check 5: Suspicious file extensions
echo -n "Checking file extensions... "
if git diff --cached --name-only | grep -E '\.(pem|key|cert|jks)$'; then
    echo -e "${RED}✗ FAIL${NC}"
    echo "Certificate/key file detected!"
    echo "Remove from staging:"
    echo "  git reset HEAD <filename>"
    FOUND_ISSUES=1
else
    echo -e "${GREEN}✓ PASS${NC}"
fi

# Check 6: Hardcoded wallets/addresses (basic check)
echo -n "Checking for hardcoded addresses... "
if git diff --cached | grep -E '0x[a-fA-F0-9]{40}' | grep -v '0xabc' | grep -v example; then
    echo -e "${YELLOW}⚠ WARNING${NC}"
    echo "Ethereum address pattern found in code"
    echo "Verify this is not a private wallet:"
    echo "  git diff --cached | grep 0x"
fi

# Summary
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $FOUND_ISSUES -eq 0 ]; then
    echo -e "${GREEN}✓ All security checks passed!${NC}"
    echo ""
    echo "Safe to commit."
    exit 0
else
    echo -e "${RED}✗ Security checks FAILED${NC}"
    echo ""
    echo "To force commit (NOT RECOMMENDED):"
    echo "  git commit --no-verify"
    echo ""
    echo "This bypasses security checks and is RISKY!"
    exit 1
fi
